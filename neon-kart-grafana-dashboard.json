{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Neon Kart Battle — Live Game Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🎮 Game Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "text": {},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neon_kart_active_players",
          "legendFormat": "Active Players",
          "refId": "A"
        }
      ],
      "title": "🟢 Active Players (Live)",
      "type": "stat"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 5, "w": 10, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neon_kart_active_players",
          "legendFormat": "Connected Players",
          "refId": "A"
        }
      ],
      "title": "📈 Player Count Over Time",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 14, "y": 1 },
      "id": 3,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "neon_kart_active_players / 20",
          "legendFormat": "Server Load",
          "refId": "A"
        }
      ],
      "title": "⚡ Server Load (Players / Max 20)",
      "type": "gauge"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{"color":"green","value":null},{"color":"red","value":1}] }
        }
      },
      "gridPos": { "h": 5, "w": 5, "x": 19, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(up{job=~\".*neon-kart.*\"} == 0) or vector(0)",
          "legendFormat": "Down Pods",
          "refId": "A"
        }
      ],
      "title": "🔴 Pods Down",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 101,
      "title": "🖥️ Node.js Process Metrics",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=~\".*neon-kart.*\"}",
          "legendFormat": "RSS Memory - {{pod}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_used_bytes{job=~\".*neon-kart.*\"}",
          "legendFormat": "Heap Used - {{pod}}",
          "refId": "B"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{job=~\".*neon-kart.*\"}",
          "legendFormat": "Heap Total - {{pod}}",
          "refId": "C"
        }
      ],
      "title": "🧠 Node.js Memory (per Pod)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "id": 6,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "rate(http_request_duration_seconds_count{job=~\".*neon-kart.*\"}[1m])",
          "legendFormat": "HTTP req/s - {{pod}}",
          "refId": "A"
        }
      ],
      "title": "🌐 HTTP Request Rate (req/s)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "id": 7,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=~\".*neon-kart.*\"}[5m]))",
          "legendFormat": "p95 latency - {{pod}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=~\".*neon-kart.*\"}[5m]))",
          "legendFormat": "p50 latency - {{pod}}",
          "refId": "B"
        }
      ],
      "title": "⏱️ HTTP Response Latency (p95 / p50)",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{job=~\".*neon-kart.*\"}",
          "legendFormat": "Active Handles - {{pod}}",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_requests_total{job=~\".*neon-kart.*\"}",
          "legendFormat": "Active Requests - {{pod}}",
          "refId": "B"
        }
      ],
      "title": "🔄 Node.js Event Loop Handles & Requests",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 102,
      "title": "☸️ Kubernetes Pod Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" }, "max": 1, "min": 0 } },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 22 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"default\", pod=~\"neon-kart.*\"}[1m])",
          "legendFormat": "CPU - {{pod}}",
          "refId": "A"
        }
      ],
      "title": "💻 Pod CPU Usage",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 22 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true } },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"default\", pod=~\"neon-kart.*\", container!=\"\"}",
          "legendFormat": "Memory - {{pod}}",
          "refId": "A"
        }
      ],
      "title": "🧱 Pod Memory Usage",
      "type": "timeseries"
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["neon-kart", "game", "nodejs", "kubernetes"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Neon Kart Battle — Observability",
  "uid": "neon-kart-dashboard",
  "version": 1
}
